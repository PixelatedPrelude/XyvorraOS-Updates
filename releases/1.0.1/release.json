{
  "version": "1.0.1",
  "type": "patch",
  "date": "2026-04-15",
  "summary": "Fix os-release canonical path, add pacman hook and restore script",
  "min_base_version": "1.0.0",
  "packages": {
    "upgrade_all": false,
    "install": []
  },
  "files": [
    {
      "source": "files/etc/os-release",
      "destination": "/etc/os-release"
    },
    {
      "source": "files/usr/lib/os-release",
      "destination": "/usr/lib/os-release"
    },
    {
      "source": "files/usr/local/bin/xyvorra-chroot-setup.sh",
      "destination": "/usr/local/bin/xyvorra-chroot-setup.sh",
      "mode": "0755"
    },
    {
      "source": "files/etc/pacman.d/hooks/99-xyvorra-osrelease.hook",
      "destination": "/etc/pacman.d/hooks/99-xyvorra-osrelease.hook"
    },
    {
      "source": "files/usr/local/bin/xyvorra-restore-osrelease",
      "destination": "/usr/local/bin/xyvorra-restore-osrelease",
      "mode": "0755"
    }
  ],
  "hooks": {
    "pre": "hooks/pre.sh",
    "post": "hooks/post.sh"
  }
}
